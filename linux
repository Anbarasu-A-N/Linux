## 2. File Permissions  
### Understanding File Permissions
r = read (4)
w = write (2)
x = execute (1)

### Viewing File Permissions
ls -l filename.txt
# Example Output:
-rwxr-xr-- 1 user group 1234 Jan 01 12:00 filename.txt
# Breakdown:
# -             : file type ( - for file, d for directory, l for link)
# rwx           : owner permissions (read, write, execute)   
# r-x           : group permissions (read, execute)
# r--           : others permissions (read only)
# 1             : number of hard links
# user          : owner of the file
# group         : group of the file
# 1234          : file size in bytes
# Jan 01 12:00  : last modified date and time
# filename.txt  : name of the file

### Changing File Permissions
# Using Symbolic Mode
chmod u+x filename.txt              # add execute permission for owner
chmod g-w filename.txt              # remove write permission for group
chmod o=r filename.txt              # set read-only permission for others
chmod u=rwx,g=rx,o=r filename.txt   # set specific permissions for owner, group, and others

# Using Numeric Mode
chmod 755 filename.txt              # set rwx for owner, rx for group, r for others
chmod 644 filename.txt              # set rw for owner, r for group and others
chmod 700 filename.txt              # set rwx for owner, no permissions for group and others

### Changing File Ownership
sudo chown newowner filename.txt                # change owner of the file to newowner
sudo chown newowner:newgroup filename.txt       # change owner to newowner and group to newgroup

sudo chown -R newowner:newgroup directory/      # change owner and group recursively for a directory

### Changing File Group
sudo chgrp newgroup filename.txt                # change group of the file to newgroup
sudo chgrp -R newgroup directory/               # change group recursively for a directory

### Special Permissions
# its used to provide special access rights to files and directories.
# Setuid (s in owner execute position)
chmod u+s filename.txt              # set setuid permission
# Setgid (s in group execute position)
chmod g+s directory/                # set setgid permission on a directory
# Sticky Bit (t in others execute position)
chmod o+t directory/                # set sticky bit on a directory


