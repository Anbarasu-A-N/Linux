### batch Command
echo "/home/user/long_running_task.sh" | batch    # schedule a long-running task to run when system load is low

### sleep Command
sleep 10                    # pause execution for 10 seconds
sleep 5m                    # pause execution for 5 minutes
sleep 1h                    # pause execution for 1 hour

### at Command
echo "/home/user/one_time_task.sh" | at 14:30    # schedule a one-time task to run at 2:30 PM today
echo "/home/user/one_time_task.sh" | at 09:00 tomorrow  # schedule a one-time task to run at 9:00 AM tomorrow

## 4. Logs

### logs Location
/var/log/

### View System Logs
sudo cat /var/log/syslog                # view system log (Debian/Ubuntu)
sudo cat /var/log/auth.log              # view authentication log (Debian/Ubuntu)
sudo cat /var/log/messages              # view system log (RedHat/CentOS)
sudo cat /var/log/secure                # view authentication log (RedHat/CentOS)


### Viewing Service Logs with journalctl
sudo journalctl -xe                     # view system logs with extra details
sudo journalctl -u service_name         # view logs for a specific service
sudo journalctl -u nginx.service        # view logs for nginx service
journalctl -u nginx -f                  # follow nginx service logs in real-time


## 5. Performance tuning
### Monitoring System Performance
top                                    # interactive process viewer
htop                                   # enhanced interactive process viewer (may need to install)
vmstat                                 # display system performance statistics
iostat                                 # display CPU and I/O statistics
free -h                                # display memory usage in human-readable format
df -h                                  # display disk space usage in human-readable format
dstat                                  # versatile resource statistics (may need to install)

### Analyzing Performance Bottlenecks
iotop                                  # display real-time disk I/O usage (may need to install)
strace                                 # trace system calls and signals (may need to install)
perf                                   # performance analysis tool (may need to install)

### Tuning System Parameters
sudo sysctl -a                         # display all kernel parameters
sudo sysctl -w net.ipv4.ip_forward=1   # enable IP forwarding
sudo sysctl -w vm.swappiness=10        # set swappiness value to 10
sudo sysctl -p                         # apply changes made to /etc/sysctl.conf

### Note:
# Always back up configuration files before making changes.

# PHASE 6: LINUX SECURITY
## 1. Basic Security Practices
### Regular Updates
sudo apt update && sudo apt upgrade -y

### Strong Passwords
sudo apt install libpam-cracklib
sudo nano /etc/pam.d/common-password
# Add the following line to enforce strong passwords:
password requisite pam_cracklib.so retry=3 minlen=8 difok=3

### SSH Security
sudo nano /etc/ssh/sshd_config
# Recommended settings:  (if it's sets to yes, change it to no but using this will disable root login via SSH)
PermitRootLogin no
PasswordAuthentication no
